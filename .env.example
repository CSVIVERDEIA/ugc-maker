# Environment
DATABASE_URL="postgresql://user:password@host:port/dbname"
DIRECT_URL="postgresql://user:password@host:port/dbname"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_here"

# Chave-mestra do vault (criptografa as API keys guardadas no banco).
# Se ausente, usa NEXTAUTH_SECRET. Em produção, defina uma própria.
ENCRYPTION_KEY=""

# ─────────────────────────────────────────────────────────────
# API keys (Replicate, ElevenLabs, Anthropic, Webhook URL):
# AGORA são configuradas na tela /settings (guardadas criptografadas no banco).
# As variáveis abaixo são OPCIONAIS — servem só de fallback/migração.
# Podem ficar vazias se você configurar tudo em /settings.
# ─────────────────────────────────────────────────────────────
REPLICATE_API_TOKEN=""
ANTHROPIC_API_KEY=""  # opcional; se vazio, roteiros usam modelo de texto do Replicate
ELEVENLABS_API_KEY="" # voz / TTS

# WEBHOOK_URL é DETECTADO AUTOMATICAMENTE pela URL pública do app (Replit/VPS).
# Só precisa definir no DEV LOCAL (a URL do ngrok), porque aí você acessa via
# localhost mas o Replicate precisa de um endereço público pra avisar.
WEBHOOK_URL=""

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# UI Theme
NEXT_PUBLIC_THEME=light
