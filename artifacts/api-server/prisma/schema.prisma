generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  credits       Int       @default(10)
  accounts      Account[]
  sessions      Session[]
  creations     Creation[]
  products      Product[]
  avatars       Avatar[]
  campaigns     Campaign[]
  secrets       Secret[]
}

model Secret {
  id        String   @id @default(cuid())
  userId    String
  name      String
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model Campaign {
  id          String   @id @default(cuid())
  userId      String
  name        String
  objective   String?
  angle       String?  @db.Text
  audience    String?  @db.Text
  cta         String?
  productId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Avatar {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?  @db.Text
  photos      String[]
  settings    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?  @db.Text
  info        Json?
  photos      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Creation {
  id           String   @id @default(cuid())
  type         String?
  title        String?
  prompt       String?  @db.Text
  url          String?  @db.Text
  createdAt    DateTime @default(now())
  userId       String

  requestId    String?  @unique
  status       String   @default("processing")
  error        String?  @db.Text

  modelId      String?
  aspectRatio  String?
  resolution   String?
  duration     Int?
  mode         String?
  inputImages  String[]

  pipeline     String?
  stage        String?
  audio        String?  @db.Text
  sceneUrl     String?  @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
